# Server Configuration
PORT=8000
DEBUG=true

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage Configuration
STORAGE_PATH=storage/uploads

# AI Provider Keys
GOOGLE_API_KEY=
TRIPO_API_KEY=
TRIPO_BASE_URL=https://api.tripo3d.ai/v2/openapi
# Tripo API version (set 3 to try v3 endpoint)
TRIPO_API_VERSION=3
# If v3 endpoint is unavailable for your account, fallback to v2 automatically.
TRIPO_ENABLE_V2_FALLBACK=true
# Optional task version/model selector if your Tripo account supports it (for example: 3.0)
TRIPO_TASK_VERSION=
# Tripo input safeguards (image is auto-compressed/resized before upload)
TRIPO_MAX_IMAGE_MB=10
TRIPO_MAX_DIMENSION=2048
TRIPO_JPEG_QUALITY=88
TRIPO_REQUEST_TIMEOUT_SEC=180

# BytePlus Seedream fallback (optional)
BYTEPLUS_API_KEY=
BYTEPLUS_MODEL=seedream-4-0
# Optional fallback order when a model is unavailable for your account/project.
BYTEPLUS_MODEL_CANDIDATES=seedream-4-5,seedream-4-0,seedream-3-0-t2i
BYTEPLUS_BASE_URL=https://ark.ap-southeast.bytepluses.com
# Recommended for max image count per free quota (minimum documented pixels)
BYTEPLUS_IMAGE_WIDTH=2560
BYTEPLUS_IMAGE_HEIGHT=1440
BYTEPLUS_WATERMARK=true

# Google Auth + JWT
GOOGLE_CLIENT_ID=
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXP_HOURS=168

# Razorpay Payment Gateway
# Get keys from: https://dashboard.razorpay.com/app/keys (Test mode for development)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

