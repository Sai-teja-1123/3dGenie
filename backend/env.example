# Server Configuration
PORT=8000
DEBUG=true

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Storage Configuration
STORAGE_PATH=storage/uploads

# AI Provider Keys
GOOGLE_API_KEY=
GOOGLE_IMAGE_MODEL=gemini-2.5-flash-image

BYTEPLUS_API_KEY=
BYTEPLUS_MODEL=seedream-4-0
BYTEPLUS_MODEL_CANDIDATES=seedream-4-5,seedream-4-0,seedream-3-0-t2i
BYTEPLUS_BASE_URL=https://ark.ap-southeast.bytepluses.com
BYTEPLUS_IMAGE_WIDTH=2560
BYTEPLUS_IMAGE_HEIGHT=1440
BYTEPLUS_WATERMARK=true

TRIPO_API_KEY=
TRIPO_BASE_URL=https://api.tripo3d.ai/v2/openapi
TRIPO_API_VERSION=3
TRIPO_ENABLE_V2_FALLBACK=true
TRIPO_TASK_VERSION=
TRIPO_MAX_IMAGE_MB=10
TRIPO_MAX_DIMENSION=2048
TRIPO_JPEG_QUALITY=88
TRIPO_REQUEST_TIMEOUT_SEC=180
TRIPO_MAX_RETRIES=3
TRIPO_RETRY_BACKOFF_SEC=1.0

# Google Auth + JWT
GOOGLE_CLIENT_ID=
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXP_HOURS=168

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

